# ============================================================
# Tg-Fun-Games-Bot — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Core Bot Settings ─────────────────────────────────────
# Obtain from @BotFather on Telegram
BOT_TOKEN=123456789:AAHdqTcvCH1vGWJxfSeofSs0K95sTVk2Dc0

# Your Telegram numeric user ID (use @userinfobot to find it)
OWNER_ID=123456789

# Space-separated list of trusted super-admin user IDs
SUDO_USERS=123456789 987654321

# Public username of the bot (without @)
BOT_USERNAME=MyAwesomeBot

# Telegram chat ID / username of the support group
SUPPORT_CHAT=@MyBotSupport

# ─── Database ──────────────────────────────────────────────
# SQLite (default / development):
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# With password:
# REDIS_URL=redis://:yourpassword@localhost:6379/0

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=1024

# ─── Logging & Monitoring ──────────────────────────────────
# Telegram channel ID where all moderation actions are logged
LOG_CHANNEL_ID=-1001234567890

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE=logs/bot.log

# ─── Bot Behaviour ─────────────────────────────────────────
# Set to True to enable maintenance mode (only SUDO_USERS can use the bot)
MAINTENANCE_MODE=False

# Maximum number of warnings before automatic action is taken
MAX_WARN_LIMIT=3

# Default action when warn limit is reached: ban | kick | mute | none
WARN_MODE=kick

# Default language / locale for new groups (IETF BCP 47)
DEFAULT_LANGUAGE=en

# Anti-flood: max messages in the time window before mute
ANTIFLOOD_LIMIT=5
ANTIFLOOD_TIME=5

# Anti-raid: number of joins in window before raid-mode kicks in
ANTIRAID_LIMIT=10
ANTIRAID_TIME=60

# ─── Economy Settings ──────────────────────────────────────
DAILY_COINS=500
WEEKLY_COINS=2500
WORK_COINS_MIN=100
WORK_COINS_MAX=500
CRIME_COINS_MIN=200
CRIME_COINS_MAX=1000
CRIME_FAIL_CHANCE=40

# ─── Cooldowns (seconds) ───────────────────────────────────
DAILY_COOLDOWN=86400
WEEKLY_COOLDOWN=604800
WORK_COOLDOWN=3600
CRIME_COOLDOWN=7200
REP_COOLDOWN=86400

# ─── Games ─────────────────────────────────────────────────
GAME_TIMEOUT=30
TRIVIA_POINTS=10
WORD_GAME_POINTS=5

# ─── Rate Limiting ─────────────────────────────────────────
# Global command rate limit per user (seconds between allowed calls)
RATE_LIMIT=1

# ─── Webhook (leave blank to use long-polling) ─────────────
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET_TOKEN=

# ─── Sentry Error Tracking (optional) ─────────────────────
SENTRY_DSN=

# ─── NSFW Detection API (optional) ────────────────────────
NSFW_API_URL=
NSFW_API_KEY=

# ─── Sticker Pack Settings ─────────────────────────────────
STICKER_BOT=@Stickers
MAX_STICKERS_PER_PACK=120

# ─── Media / File Limits ───────────────────────────────────
# Maximum file size in MB accepted for processing
MAX_FILE_SIZE_MB=50
